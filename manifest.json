{
  "manifest_version": 3,
  "name": "Universal Audio Translator",
  "version": "1.0.0",
  "description": "Herhangi bir web sayfasındaki yabancı dildeki sesi gerçek zamanlı olarak çevirin",
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/audio-processor.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
